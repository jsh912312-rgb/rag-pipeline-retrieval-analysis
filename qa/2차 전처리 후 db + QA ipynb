\"고려대학교\",\n","    \"서울대\":         \"서울대학교\",\n","    \"한양대\":         \"한양대학교\",\n","    \"강원대\":         \"강원대학교\",\n","    \"한림대\":         \"한림대학교\",\n","}\n","\n","DEPT_HINT_PATTERN = re.compile(\n","    r'([가-힣]{2,10}(?:학과|학부|전공|의예과|치의예과|약학과|간호학과))'\n",")\n","\n","MAX_CONTEXT_CHARS = 3000\n","\n","\n","def normalize_query(query: str) -> tuple[str, dict]:\n","    auto_filters = {}\n","    normalized = query\n","\n","    for short, full in UNIV_NORMALIZE.items():\n","        # full이 이미 query에 있으면 치환 스킵\n","        if short in query and full not in query:\n","            normalized = normalized.replace(short, full)\n","            auto_filters[\"university\"] = full\n","            break\n","        elif full in query:\n","            auto_filters[\"university\"] = full\n","            break\n","\n","    if \"정시\" in query:\n","        auto_filters[\"admission_type\"] = \"정시\"\n","    elif \"수시\" in query:\n","        auto_filters[\"admission_type\"] = \"수시\"\n","\n","    dept_matches = DEPT_HINT_PATTERN.findall(query)\n","    if dept_matches:\n","        auto_filters[\"dept_keyword\"] = dept_matches[0]\n","\n","    return normalized, auto_filters\n","\n","\n","def generate_ai_qa(\n","    query: str,\n","    searcher,\n","    qa_pipe,\n","    top_k: int = 7,\n","    extra_filters: Optional[dict] = None,\n","    verbose: bool = True,\n",") -> str:\n","\n","    # 1. 쿼리 정규화 + 자동 필터 추출\n","    normalized_query, auto_filters = normalize_query(query)\n","    filters = {**auto_filters, **(extra_filters or {})}\n","\n","    if verbose:\n","        print(f\"🔍 쿼리: {query}\")\n","        if normalized_query != query:\n","            print(f\"   정규화: {normalized_query}\")\n","        if filters:\n","            print(f\"   자동 필터: {filters}\")\n","\n","    # 2. 벡터 검색\n","    results = searcher.search(normalized_query, top_k=top_k, **filters)\n","\n","    # 결과 부족 시 dept_keyword 제거 후 재검색\n","    if len(results) < 3 and \"dept_keyword\" in filters:\n","        relaxed = {k: v for k, v in filters.items() if k != \"dept_keyword\"}\n","        if verbose:\n","            print(f\"   ⚠️  결과 부족({len(results)}개) → 필터 완화 재검색: {relaxed}\")\n","        results = searcher.search(normalized_query, top_k=top_k, **relaxed)\n","\n","    if not results:\n","        return \"검색 결과가 없습니다. 질문을 더 구체적으로 입력해 주세요.\"\n","\n","    # 3. 컨텍스트 구성 (길이 제한)\n","    context_text = \"\"\n","    for i, res in enumerate(results):\n","        header = (\n","            f\"[문서 {i+1}] \"\n","            f\"학교: {res['university']} / \"\n","            f\"전형시즌: {res['admission_type']} / \"\n","            f\"전형유형: {res['track']} / \"\n","            f\"항목: {res['section']}\\n\"\n","        )\n","        ec = res[\"enriched_content\"]\n","\n","        # 요약 섹션이 있으면 요약만 사용 (길이 절약)\n","        if \"[전형별 모집인원 요약]\" in ec:\n","            first_line = ec.split(\"\\n\")[0]\n","            summary_part = ec[ec.find(\"[전형별 모집인원 요약]\"):]\n","            content_to_use = first_line + \"\\n\" + summary_part\n","        else:\n","            content_to_use = ec[:800]\n","\n","        chunk = header + f\"내용:\\n{content_to_use}\\n\\n\"\n","\n","        if len(context_text) + len(chunk) > MAX_CONTEXT_CHARS:\n","            break\n","        context_text += chunk\n","\n","    # 4. 프롬프트 구성\n","    system_prompt = \"\"\"너는 대학 입시 요강 QA 전문가야.\n","아래 [입시 요강 문서]의 내용에만 근거하여 답변해.\n","\n","답변 규칙:\n","- 문서에 없는 내용은 절대 추측하지 말고 \"해당 정보가 문서에 없습니다\"라고 답해.\n","- 모집인원 관련 질문: [전형별 모집인원 요약] 섹션의 \"XXX 모집인원 총 N명\" 형태 문장을 우선 참고해.\n","- 숫자는 반드시 정확히 확인하고 출처 문서 번호를 함께 언급해.\n","- 수시/정시가 구분되면 반드시 구분해서 답변해.\n","- 간결하고 명확하게 답변해.\"\"\"\n","\n","    messages = [\n","        {\"role\": \"system\", \"content\": system_prompt},\n","        {\n","            \"role\": \"user\",\n","            \"content\": f\"[입시 요강 문서]:\\n{context_text}\\n\\n[질문]:\\n{query}\",\n","        },\n","    ]\n","\n","    # 5. 답변 생성\n","    if verbose:\n","        print(f\"🤖 AI 답변 생성 중... (참고 문서 {len(results)}개)\")\n","\n","    outputs = qa_pipe(\n","        messages,\n","        max_new_tokens=256,\n","        do_sample=False,   # greedy decoding — 메모리 절약 + 일관성 향상\n","    )\n","    ans = outputs[0][\"generated_text\"][-1][\"content\"]\n","\n","    if verbose:\n","        print(\"\\n\" + \"=\" * 50)\n","        print(\"✨ AI 최종 응답:\")\n","        print(ans)\n","        print(\"=\" * 50)\n","        print(f\"\\n참고 Doc IDs: {[r['doc_id'] for r in results]}\")\n","\n","    return ans\n","\n","\n","# ── 테스트 실행 ────────────────────────────────────────────\n","if __name__ == \"__main__\":\n","    test_queries = [\n","        \"시립대학교 환경공학부 정시 모집인원 수는?\",\n","        \"연세대학교 국어국문학과 수시 모집인원은?\",\n","        \"고려대학교 경영학과 정시 모집인원은?\",\n","        \"연세대 논술전형 수능 최저학력기준은?\",\n","    ]\n","\n","    for q in test_queries:\n","        print(f\"\\n{'='*60}\")\n","        answer = generate_ai_qa(q, searcher, qa_pipe)\n","        print()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"XjDP1L7ZbD26","executionInfo":{"status":"ok","timestamp":1778341420956,"user_tz":-540,"elapsed":417705,"user":{"displayName":"지수현","userId":"01973714090881485046"}},"outputId":"9963e262-788a-4719-f009-22f0c5f3f9cd"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["The following generation flags are not valid and may be ignored: ['temperature']. Set `TRANSFORMERS_VERBOSITY=info` for more details.\n","Passing `generation_config` together with generation-related arguments=({'max_new_tokens', 'do_sample'}) is deprecated and will be removed in future versions. Please pass either a `generation_config` object OR all generation parameters explicitly, but not both.\n","Setting `pad_token_id` to `eos_token_id`:128001 for open-end generation.\n","Both `max_new_tokens` (=256) and `max_length`(=20) seem to have been set. `max_new_tokens` will take precedence. Please refer to the documentation for more information. (https://huggingface.co/docs/transformers/main/en/main_classes/text_generation)\n"]},{"output_type