SentenceTransformer\n","from pathlib import Path\n","\n","# ── 경로 설정 ──────────────────────────────────────────────\n","INPUT_JSON   = \"admission_data_v2.json\"   # ← 재보강된 파일\n","OUTPUT_INDEX = \"faiss_index.bin\"\n","OUTPUT_META  = \"metadata.json\"\n","\n","# ── 1. 데이터 로드 ─────────────────────────────────────────\n","print(\"📂 데이터 로드 중...\")\n","with open(INPUT_JSON, \"r\", encoding=\"utf-8\") as f:\n","    data = json.load(f)\n","\n","# 노이즈 청크 제거 (text_length < 50)\n","data = [d for d in data if not d.get(\"flag_short_chunk\", False)]\n","print(f\"   총 청크: {len(data)}개 (노이즈 제거 후)\")\n","\n","# ── 2. 임베딩 텍스트 구성 ──────────────────────────────────\n","def build_embed_text(doc: dict) -> str:\n","    \"\"\"\n","    검색 품질 향상을 위한 임베딩 텍스트 구성 전략:\n","    1. 대학·전형·섹션 컨텍스트를 앞에 명시 (필터 없는 쿼리도 매칭되도록)\n","    2. dept_list 학과명을 자연어 문장으로 변환 (단순 나열 → \"XXX 모집 학과\")\n","    3. enriched_content 사용 (v2에서 표 청크 요약이 완전히 포함됨)\n","    \"\"\"\n","    univ     = doc[\"university\"]\n","    adm_type = doc[\"admission_type\"]\n","    track    = doc[\"track\"]\n","    section  = doc[\"section\"]\n","\n","    # dept_list 자연어화\n","    raw_depts = doc.get(\"dept_list\") or []\n","    if isinstance(raw_depts, str):\n","        raw_depts = [d.strip() for d in raw_depts.split(\",\") if d.strip()]\n","    depts_str = \", \".join(raw_depts) if raw_depts else \"공통\"\n","\n","    # 학과 자연어 문장 (임베딩 검색 품질 향상)\n","    if raw_depts and raw_depts != [\"공통\"]:\n","        dept_sentence = f\"{univ} {adm_type} 모집 학과: {depts_str}. \"\n","    else:\n","        dept_sentence = \"\"\n","\n","    return (\n","        f\"{univ} {adm_type} {track}전형 {section}. \"\n","        f\"{dept_sentence}\"\n","        f\"{doc['enriched_content']}\"\n","    )\n","\n","texts = [build_embed_text(d) for d in data]\n","\n","# ── 3. 모델 로드 & 임베딩 ─────────────────────────────────\n","print(\"🤖 임베딩 모델 로드 중... (첫 실행 시 다운로드)\")\n","model = SentenceTransformer(\"jhgan/ko-sroberta-multitask\")\n","\n","print(\"⚡ 임베딩 생성 중...\")\n","embeddings = model.encode(\n","    texts,\n","    batch_size=64,\n","    show_progress_bar=True,\n","    normalize_embeddings=True,   # 코사인 유사도용 정규화\n","    convert_to_numpy=True,\n",")\n","print(f\"   임베딩 shape: {embeddings.shape}\")  # (N, 768)\n","\n","# ── 4. FAISS 인덱스 생성 & 저장 ───────────────────────────\n","print(\"🗂  FAISS 인덱스 생성 중...\")\n","dim = embeddings.shape[1]\n","index = faiss.IndexFlatIP(dim)\n","index.add(embeddings.astype(np.float32))\n","\n","faiss.write_index(index, OUTPUT_INDEX)\n","print(f\"   저장 완료: {OUTPUT_INDEX}  ({index.ntotal}개 벡터)\")\n","\n","# ── 5. 메타데이터 저장 ────────────────────────────────────\n","meta = [\n","    {\n","        \"doc_id\":           d[\"doc_id\"],\n","        \"university\":       d[\"university\"],\n","        \"admission_type\":   d[\"admission_type\"],\n","        \"track\":            d[\"track\"],\n","        \"section\":          d[\"section\"],\n","        \"page\":             d[\"page\"],\n","        \"has_nonsul\":       d[\"has_nonsul\"],\n","        \"has_suneung\":      d[\"has_suneung\"],\n","        \"text_length\":      d[\"text_length\"],\n","        \"keywords\":         d[\"keywords\"],\n","        \"content\":          d[\"content\"],\n","        \"is_header_chunk\":  d[\"is_header_chunk\"],\n","        \"has_dept_data\":    d[\"has_dept_data\"],\n","        \"dept_list\":        d[\"dept_list\"],\n","        \"enriched_content\": d[\"enriched_content\"],\n","    }\n","    for d in data\n","]\n","\n","with open(OUTPUT_META, \"w\", encoding=\"utf-8\") as f:\n","    json.dump(meta, f, ensure_ascii=False, indent=2)\n","print(f\"   저장 완료: {OUTPUT_META}\")\n","\n","print(\"\\n✅ Ingestion 완료!\")\n","print(f\"   다음 단계: python 02_search.py 실행\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":565,"referenced_widgets":["5861bd3cabbb42f794133346f7c1a7d7","17b82d48ecb74c01bf95fe1f58e459b0","86f10506bd614fa6ae57ff55f8404fb1","cb9ffe8d21934a30825cb608510e3ba7","e8edb47d8bc04efa9c69235e4f47db6f","31f9e