hgan/ko-sroberta-multitask\"\n","\n","\n","class AdmissionSearcher:\n","\n","    def __init__(self):\n","        print(\"🤖 모델 & 인덱스 로드 중...\")\n","        self.model = SentenceTransformer(MODEL_NAME)\n","        self.index = faiss.read_index(INDEX_PATH)\n","        with open(META_PATH, \"r\", encoding=\"utf-8\") as f:\n","            self.meta = json.load(f)\n","        print(f\"   인덱스: {self.index.ntotal}개 벡터 로드 완료\\n\")\n","\n","    def search(\n","        self,\n","        query: str,\n","        top_k: int = 5,\n","        # ── 메타데이터 필터 (None이면 필터 없음) ──\n","        university: Optional[str] = None,       # 예: \"연세대학교\"\n","        track: Optional[str] = None,            # 예: \"논술\"\n","        section: Optional[str] = None,          # 예: \"수능최저\"\n","        admission_type: Optional[str] = None,   # 예: \"수시\"\n","        only_suneung: bool = False,\n","        only_nonsul: bool = False,\n","        dept_keyword: Optional[str] = None,     # 예: \"환경공학부\" — enriched_content 키워드 필터\n","        min_score: float = 0.0,                 # 유사도 최소 임계값 (0.0~1.0)\n","    ) -> list[dict]:\n","\n","        # 1. 쿼리 임베딩\n","        query_vec = self.model.encode(\n","            [query],\n","            normalize_embeddings=True,\n","            convert_to_numpy=True,\n","        ).astype(np.float32)\n","\n","        # 2. 후보 검색 — 필터 감안해 넉넉하게 가져옴\n","        fetch_k = min(top_k * 50, self.index.ntotal)\n","        scores, indices = self.index.search(query_vec, fetch_k)\n","\n","        # 3. 메타데이터 필터 적용\n","        results = []\n","        for score, idx in zip(scores[0], indices[0]):\n","            if idx == -1:\n","                continue\n","            if float(score) < min_score:\n","                continue\n","\n","            doc = self.meta[idx]\n","\n","            if university and doc[\"university\"] != university:\n","                continue\n","            if track and doc[\"track\"] != track:\n","                continue\n","            if section and doc[\"section\"] != section:\n","                continue\n","            if admission_type and doc[\"admission_type\"] != admission_type:\n","                continue\n","            if only_suneung and doc[\"has_suneung\"] != 1:\n","                continue\n","            if only_nonsul and doc[\"has_nonsul\"] != 1:\n","                continue\n","\n","            # 학과 키워드 필터: enriched_content 또는 dept_list에서 검색\n","            if dept_keyword:\n","                dept_list_str = str(doc.get(\"dept_list\", \"\"))\n","                enriched = doc.get(\"enriched_content\", \"\")\n","                if dept_keyword not in enriched and dept_keyword not in dept_list_str:\n","                    continue\n","\n","            results.append({\n","                \"score\":            round(float(score), 4),\n","                \"doc_id\":           doc[\"doc_id\"],\n","                \"university\":       doc[\"university\"],\n","                \"admission_type\":   doc[\"admission_type\"],\n","                \"track\":            doc[\"track\"],\n","                \"section\":          doc[\"section\"],\n","                \"page\":             doc[\"page\"],\n","                \"keywords\":         doc.get(\"keywords\", \"\"),\n","                \"content\":          doc[\"content\"],\n","                \"dept_list\":        doc.get(\"dept_list\", []),\n","                \"enriched_content\": doc[\"enriched_content\"],\n","            })\n","\n","            if len(results) >= top_k:\n","                break\n","\n","        return results\n","\n","    def print_results(self, results: list[dict], query: str):\n","        print(f\"\\n{'='*60}\")\n","        print(f\"🔍 쿼리: {query}\")\n","        print(f\"{'='*60}\")\n","        if not results:\n","            print(\"❌ 검색 결과 없음\")\n","            return\n","        for i, r in enumerate(results, 1):\n","            print(f\"\\n[{i}위]  score={r['score']}  |  {r['university']}  |  {r['track']}  |  {r['section']}  |  p.{r['page']}\")\n","            print(f\"  doc_id: {r['doc_id']}\")\n","            print(f\"  내용: {r['enriched_content'][:200]}{'...' if len(r['enriched_content'])>200 else ''}\")\n","        print()\n","\n","\n","# ── 대화형 검색 (단독 실행 시) ────────────────────────────\n","if __name__ == \"__main__\":\n","    searcher = AdmissionSearcher()\n","\n","    print(\"=\" * 60)\n","    print(\"입시 RAG 검색기  |  종료: q\")\n","    print(\"=\" * 60)\n","    print(\"필터 사용법 예시:\")\n","    print(\"  연세대 논술 수능최저  @대학=연세대학교 @전형=논술\")\n","    print(\"  시립대 환경공학부 정시 모집인원  @대학=시립대학교 @시즌=정시\")\n","    print(\"  고려대 학종 제출서류  @대학=고려대학교 @섹션=제출서류\")\n","    print()\n","\n","    while True:\n","        raw = input(\"쿼리 입력: \").strip()\n","        if not raw or raw.lower() == \"q\":\n","            break\n","\n","        # 인라인 필터 파싱 (@키=값 형식)\n","        import re\n","        filters = {}\n","        query_clean = raw\n","        for match in re.finditer(r\"@(\\S+)=(\\S+)\", raw):\n","            filters[match.group(1)] = match.group(2)\n","            query_clean = query_clean.replace(match.group(0), \"\").strip()\n","\n","        key_map = {\n","            \"대학\":   \"university\",\n","            \"전형\":   \"track\",\n","            \"섹션\":   \"section\",\n","            \"시즌\":   \"admission_type\",\n","            \"학과\":   \"dept_keyword\",\n","        }\n","\n","        search_kwargs = {}\n","        for k, v in filters.items():\n","            mapped = key_map.get(k, k)\n","            search_kwargs[mapped] = v\n","\n","        results = searcher.search(query_clean, top_k=5, **search_kwargs)\n","        searcher.print_results(results, query_clean)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":408,"referenced_widgets":["a85edd3caf5b4522b31efe0d58d44551","764a0fadb4714e479209f15aaf5c96ad","4f233acdf9114a49bda68c3654ad980f","282f9135c26e4323804c361e95f82b85","5105deb02fba461d8b71645d1f016487","bc342c558ca94081afccd14967599ff5","435652b2afd94efca698795a391988ea","4b568b6ef