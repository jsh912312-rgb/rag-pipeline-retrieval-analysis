nt=2)"],"metadata":{"id":"Cjp3I0BfQfiW"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["\"\"\"\n","rebuild_enriched.py\n","===================\n","admission_data_improved.json의 enriched_content를 전면 재보강\n","\n","핵심 개선:\n","1. 표 청크의 모든 학과+모집인원을 자연어 요약에 완전 포함\n","2. 학과명 자연어 문장 생성 (임베딩 품질 향상)\n","3. 대학/전형/학과 컨텍스트를 enriched_content 앞에 명시\n","\"\"\"\n","\n","import json, re, copy\n","from pathlib import Path\n","\n","INPUT  = \"admission_data_improved.json\"\n","OUTPUT = \"admission_data_v2.json\"\n","\n","# ── 학과명 추출 패턴 ──────────────────────────────────────\n","DEPT_PATTERN = re.compile(\n","    r'([가-힣][가-힣·†()·/\\w]*'\n","    r'(?:학과|학부|전공부|전공|의예과|치의예과|약학과|간호학과|교육과|교육학부|학과부))'\n","    r'[†#*♠◈()\\s]*'\n","    r'(\\d{1,3})'\n",")\n","\n","def extract_dept_totals(content: str, min_total: int = 5) -> list[tuple[str, int]]:\n","    \"\"\"content에서 (학과명, 총정원) 리스트 추출 (중복 제거)\"\"\"\n","    seen = {}\n","    for m in DEPT_PATTERN.finditer(content):\n","        dept = m.group(1).strip().rstrip('†#*()')\n","        dept = re.sub(r'\\s+', '', dept)  # 공백 정리\n","        total = int(m.group(2))\n","        if total >= min_total and dept not in seen:\n","            seen[dept] = total\n","    return list(seen.items())\n","\n","\n","def build_enriched_content(doc: dict) -> str:\n","    \"\"\"enriched_content 완전 재생성\"\"\"\n","    univ     = doc[\"university\"]\n","    adm_type = doc[\"admission_type\"]\n","    track    = doc[\"track\"]\n","    section  = doc[\"section\"]\n","    content  = doc[\"content\"]\n","\n","    # ── 1. 헤더 컨텍스트 ──────────────────────────────────\n","    header = f\"[{univ}] [{adm_type}] [{track}전형] [{section}]\\n\"\n","\n","    # ── 2. 표 청크 → 자연어 요약 생성 ───────────────────\n","    dept_totals = extract_dept_totals(content)\n","\n","    if not dept_totals:\n","        # 표 청크가 아닌 경우: 헤더만 붙이고 원본 유지\n","        return header + content\n","\n","    # 자연어 요약 생성\n","    summary_lines = []\n","    for dept, total in dept_totals:\n","        summary_lines.append(\n","            f\"{univ} {adm_type} {dept} 모집인원 총 {total}명\"\n","        )\n","\n","    # 기존 요약 섹션 제거 후 재생성\n","    base = content\n","    if \"[전형별 모집인원 요약]\" in content:\n","        base = content[:content.find(\"[전형별 모집인원 요약]\")].rstrip()\n","\n","    new_summary = \"\\n\\n[전형별 모집인원 요약]\\n\" + \"\\n\".join(summary_lines)\n","\n","    return header + base + new_summary\n","\n","\n","# ── 메인 처리 ─────────────────────────────────────────────\n","print(\"📂 데이터 로드 중...\")\n","with open(INPUT, \"r\", encoding=\"utf-8\") as f:\n","    data = json.load(f)\n","\n","print(f\"   총 {len(data)}개 청크 처리 시작\")\n","\n","changed = 0\n","for doc in data:\n","    new_enriched = build_enriched_content(doc)\n","    if new_enriched != doc[\"enriched_content\"]:\n","        doc[\"enriched_content\"] = new_enriched\n","        changed += 1\n","\n","print(f\"   enriched_content 변경된 청크: {changed}개\")\n","\n","with open(OUTPUT, \"w\", encoding=\"utf-8\") as f:\n","    json.dump(data, f, ensure_ascii=False, indent=2)\n","\n","print(f\"✅ 저장 완료: {OUTPUT}\")"],"metadata":{"id":"r0K5kB_keM7Z"},"execution_count":null,"outputs":[]}]}