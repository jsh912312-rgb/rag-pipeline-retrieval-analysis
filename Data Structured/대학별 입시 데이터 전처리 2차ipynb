_quota(text):\n","    keywords = [\"모집인원\", \"선발인원\", \"인원\", \"정원\"]\n","    return any(k in str(text) for k in keywords)\n","\n","\n","def is_structured_quota(text):\n","    return (\n","        has_quota(text) and\n","        any(k in str(text) for k in [\"학과\", \"전공\", \"부\", \"계열\"])\n","    )\n","\n","\n","# =========================\n","# 2️⃣ keywords 태깅\n","# =========================\n","df.loc[df[\"content\"].apply(has_quota), \"keywords\"] += \", 모집인원\"\n","df.loc[df[\"content\"].apply(is_structured_quota), \"keywords\"] += \", 모집인원표\"\n","\n","\n","# =========================\n","# 3️⃣ keywords 정리 (중복 제거)\n","# =========================\n","def clean_keywords(x):\n","    parts = [p.strip() for p in str(x).split(\",\") if p.strip()]\n","    return \", \".join(sorted(set(parts)))\n","\n","df[\"keywords\"] = df[\"keywords\"].apply(clean_keywords)\n","\n","\n","# =========================\n","# 4️⃣ 모집인원표만 필터링\n","# =========================\n","quota_df = df[df[\"keywords\"].str.contains(\"모집인원표\", na=False)].copy()\n","\n","\n","# =========================\n","# 5️⃣ 학과명 추출 (핵심🔥)\n","# =========================\n","def extract_dept(line):\n","    pattern = r'([가-힣A-Za-z0-9·\\(\\)\\s]+?(학과|전공|학부|계열))'\n","\n","    match = re.search(pattern, line)\n","\n","    if match:\n","        return match.group(1).strip()\n","\n","    return None\n","\n","\n","# =========================\n","# 6️⃣ 모집인원 표 파싱\n","# =========================\n","def parse_quota_table(text):\n","    results = []\n","\n","    lines = str(text).split(\"\\n\")\n","\n","    for line in lines:\n","        line = line.strip()\n","        if not line:\n","            continue\n","\n","        # ❌ 1. 연도 제거\n","        if re.search(r'20\\d{2}', line):\n","            continue\n","\n","        # ❌ 2. 전형요소 제거\n","        if any(k in line for k in [\"전형요소\", \"평가\", \"반영\", \"비율\"]):\n","            continue\n","\n","        # # ❌ 3. 숫자 과다 제거\n","        numbers = re.findall(r'\\d+', line)\n","        # if len(numbers) > 6 or len(numbers) < 2:\n","        #     continue\n","\n","        # if not extract_dept(line):\n","        #     continue\n","\n","        # ✅ 4. 학과명 추출\n","        dept = extract_dept(line)\n","        if not dept:\n","            continue\n","\n","        # ✅ 5. 모집인원 처리\n","        if len(numbers) >= 3:\n","            safe_part = f\"모집인원: {', '.join(numbers)}명\"\n","\n","            labeled_part = (\n","                f\"추천형: {numbers[0]}명 / \"\n","                f\"국제형: {numbers[1]}명 / \"\n","                f\"활동우수형: {numbers[2]}명\"\n","            )\n","\n","            result = f\"학과: {dept} / {safe_part} / {labeled_part}\"\n","            results.append(result)\n","\n","    return \" | \".join(results)\n","\n","\n","# =========================\n","# 7️⃣ key-value 변환 실행\n","# =========================\n","quota_df[\"key_value_auto\"] = quota_df[\"content\"].apply(parse_quota_table)\n","\n","\n","# =========================\n","# 8️⃣ 원본 df에 병합\n","# =========================\n","df.loc[quota_df.index, \"key_value_auto\"] = quota_df[\"key_value_auto\"]\n","\n","\n","# =========================\n","# 9️⃣ 결과 확인\n","# =========================\n","print(\"===== 결과 미리보기 =====\")\n","print(df[[\"content\", \"keywords\", \"key_value_auto\"]].head(10))\n","\n","\n","# =========================\n","# 🔟 디버깅 (추천🔥)\n","# =========================\n","\n","# 1. 파싱 안된 것 확인\n","print(\"\\n===== 파싱 실패 =====\")\n","print(quota_df[quota_df[\"key_value_auto\"] == \"\"][[\"content\"]].head(5))\n","\n","# 2. 잘된 것 확인\n","print(\"\\n===== 파싱 성공 =====\")\n","print(quota_df[quota_df[\"key_value_auto\"] != \"\"][[\"key_value_auto\"]].head(5))\n","# df.to_csv(\"processed.csv\", index=False)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"zKUqYgVFDoIr","executionInfo":{"status":"ok","timestamp":1778237582184,"user_tz":-540,"elapsed":134,"user":{"displayName":"지수현","userId":"01973714090881485046"}},"outputId":"63981cda-04e6-4d12-cae4-3317574ec19f"}